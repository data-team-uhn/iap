{
  "bundles": [
    {
      "id": "${project.groupId}:${project.artifactId}:${project.version}",
      "start-order": "26"
    }
  ],
  "configurations": {
    "org.apache.sling.jcr.repoinit.RepositoryInitializer~workflows": {
      "service.ranking:Integer": 300,
      "scripts": [
        "create path (wf:WorkflowsHomepage) /Workflows",
        "create path (wf:WorkflowTypesHomepage) /WorkflowTypes",
        "create service user workflows \n set ACL for workflows \n allow jcr:all on / \n end"
      ]
    },
    "org.apache.sling.serviceusermapping.impl.ServiceUserMapperImpl.amended~workflows": {
      "user.mapping": ["io.uhndata.iap.workflows:workflows=[workflows]"]
    }
  }
}
