<sling = 'http://sling.apache.org/jcr/sling/1.0'>
<iap = 'https://iap.uhndata.io/'>
<cond = 'https://iap.uhndata.io/cond/'>
<sch = 'https://iap.uhndata.io/sch/'>

//-----------------------------------------------------------------------------
//
// Schemas: templates describing the institutional process required for
// approving a submission: what questions must be answered by the submitter,
// which documents must be provided, which approvals are needed...
//
// A schema is a container whose actual content lives in versions: editing a
// schema never changes what past submissions were judged against, it produces
// a new version that future submissions will reference.
//
//-----------------------------------------------------------------------------

//-----------------------------------------------------------------------------
// Homepage node for the /Schemas root path.
[sch:SchemasHomepage] > iap:EntityHomepage
  - sling:resourceType (STRING) = "sch/SchemasHomepage" mandatory autocreated protected
  - sling:resourceSuperType (STRING) = "iap/EntityHomepage" mandatory autocreated protected

  // Allow any other properties for extensibility
  - * (UNDEFINED)
  - * (UNDEFINED) multiple

  // Contains schema definitions
  + * (sch:Schema) = sch:Schema

  // Allow any other children for extensibility
  + * (nt:base) = nt:unstructured

//-----------------------------------------------------------------------------
// A named institutional schema. This is only a container identifying the
// schema; the actual requirements live in its versions.
[sch:Schema] > iap:Entity
  - sling:resourceType (STRING) = "sch/Schema" mandatory autocreated protected

  // Human-readable name for this schema
  - title (STRING) mandatory

  // When false, no new submissions may be created against any version of this schema
  - active (BOOLEAN) = false

  // Allow any other properties for extensibility
  - * (UNDEFINED)
  - * (UNDEFINED) multiple

  // Defined versions of this schema
  + * (sch:SchemaVersion) = sch:SchemaVersion

  // Allow any other children for extensibility
  + * (nt:base) = nt:unstructured

//-----------------------------------------------------------------------------
// A particular version of a schema; holds the requirements a submission
// must fulfill. Submissions reference a specific version.
[sch:SchemaVersion] > iap:Entity
  // The list of requirements is orderable, so they can be presented to the
  // submitter and reviewer in a deliberate sequence.
  orderable

  - sling:resourceType (STRING) = "sch/SchemaVersion" mandatory autocreated protected

  // Mandatory version label, e.g. "1.0"
  - version (STRING) mandatory

  // Optional description of this version
  - description (STRING)

  // When false, no new submissions may be created against this version
  - active (BOOLEAN) = false

  // The user workflow driving submissions under this schema version.
  // References the exact wf:WorkflowVersion to be instantiated, so that a
  // schema version completely freezes the process its submissions follow;
  // changing the workflow requires publishing a new schema version.
  - workflow (REFERENCE)

  // Allow any other properties for extensibility
  - * (UNDEFINED)
  - * (UNDEFINED) multiple

  // What the submission must fulfill: sets of questions to answer, documents
  // to provide, approvals to obtain, and future requirement types
  + * (sch:Requirement)

  // Allow any other children for extensibility
  + * (nt:base) = nt:unstructured

//-----------------------------------------------------------------------------
// Abstract base shared by everything that may appear in the body of a form: a
// single question, or a section grouping more items. Lets callers ask for
// "the items" of a section or form without caring whether each one is a
// question or a subsection. Conditionable, so every item may carry a single
// condition controlling whether it is shown to the submitter.
[sch:FormItem] > iap:EntityPart, cond:Conditionable
  abstract

  // Hardcode the supertype to the parent sch/FormItem type.
  - sling:resourceSuperType (STRING) = "sch/FormItem" mandatory autocreated protected

//-----------------------------------------------------------------------------
// A logical grouping of questions; sections may be nested.
[sch:Section] > sch:FormItem
  // The list of items is orderable, so they can be presented to the
  // submitter in a deliberate sequence.
  orderable

  - sling:resourceType (STRING) = "sch/Section" mandatory autocreated protected

  // Human-readable name for this section
  - title (STRING) mandatory

  // Optional description displayed to the submitter
  - description (STRING)

  // Allow any other properties for extensibility
  - * (UNDEFINED)
  - * (UNDEFINED) multiple

  // The questions and subsections grouped in this section
  + * (sch:FormItem)

  // Allow any other children for extensibility
  + * (nt:base) = nt:unstructured

//-----------------------------------------------------------------------------
// A single question the submitter must answer.
// Referenceable so that submission answers can point back to it.
[sch:Question] > sch:FormItem, mix:referenceable
  - sling:resourceType (STRING) = "sch/Question" mandatory autocreated protected

  // The question text shown to the submitter
  - text (STRING) mandatory

  // Optional longer explanation displayed to the submitter
  - description (STRING)

  // Expected answer type: text, long, double, boolean, date, file
  - dataType (STRING) = "text" mandatory autocreated

  // Whether an answer must be provided before submitting
  - required (BOOLEAN) = false

  // Whether more than one value may be provided
  - multiple (BOOLEAN) = false

  // Allow any other properties for extensibility
  - * (UNDEFINED)
  - * (UNDEFINED) multiple

  // Allow any other children for extensibility
  + * (nt:base) = nt:unstructured

//-----------------------------------------------------------------------------
// Abstract base for anything a submission must fulfill: a set of questions
// to answer, an expected document, a required approval, or future
// requirement types. Referenceable so that submission parts (answers,
// documents, reviews) can point back at the requirement they fulfill.
// Conditionable, so every requirement may carry a single condition
// controlling whether it applies to a submission.
[sch:Requirement] > iap:EntityPart, mix:referenceable, cond:Conditionable
  // This is an abstract node type, specific requirement types must be defined.
  abstract

  // Hardcode the supertype to the parent sch/Requirement type.
  - sling:resourceSuperType (STRING) = "sch/Requirement" mandatory autocreated protected

  // Short name for this requirement, e.g. "Patient consent"
  - label (STRING) mandatory

  // A description displayed to the submitter, explaining what is expected
  - description (STRING)

  // Allow any other properties for extensibility
  - * (UNDEFINED)
  - * (UNDEFINED) multiple

  // Allow any other children for extensibility
  + * (nt:base) = nt:unstructured

//-----------------------------------------------------------------------------
// A set of questions, grouped into sections, that the submitter must answer
// to fulfill this requirement. This is how a schema version's own
// questions are expressed: as a (typically unconditional, always required)
// form requirement.
[sch:FormRequirement] > sch:Requirement
  // The list of items is orderable, so they can be presented to the
  // submitter in a deliberate sequence.
  orderable

  - sling:resourceType (STRING) = "sch/FormRequirement" mandatory autocreated protected

  // The questions and sections making up this form
  + * (sch:FormItem)

//-----------------------------------------------------------------------------
// A document that the submitter is expected to provide, e.g. the patient
// consent form, in an expected format described by this requirement.
[sch:DocumentRequirement] > sch:Requirement
  - sling:resourceType (STRING) = "sch/DocumentRequirement" mandatory autocreated protected

  // Accepted MIME types for the uploaded document, e.g. application/pdf
  - acceptedFileTypes (STRING) multiple

  // Prompt for an AI agent that pre-checks whether the document
  // provided by the submitter meets this requirement
  - aiCheckPrompt (STRING)

  // Optional blank template document offered to submitters
  + template (nt:file)

//-----------------------------------------------------------------------------
// An approval that must be granted before a submission is accepted,
// e.g. "REB approval".
[sch:ApprovalRequirement] > sch:Requirement
  - sling:resourceType (STRING) = "sch/ApprovalRequirement" mandatory autocreated protected

  // Principal name of the group whose members may grant this approval
  - approverGroup (STRING)
