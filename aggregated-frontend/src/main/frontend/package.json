{
  "type": "module",
  "license": "Apache-2.0",
  "name": "iap-aggregated-frontend",
  "description": "IAP is a software tool for streamlining research proposal authorization.",
  "repository": {
    "url": "https://github.com/data-team-uhn/iap.git",
    "directory": "aggregated-frontend/src/main/frontend",
    "type": "git"
  },
  "author": "UHN DATA",
  "browserslist": [
    "baseline widely available"
  ],
  "babel": {
    "presets": [
      ["@babel/preset-env", {
        "bugfixes": true
      }],
      ["@babel/preset-react", {
        "runtime": "automatic"
      }],
      "@babel/preset-typescript"
    ]
  },
  "scripts": {
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{js,jsx,ts,tsx}' --fix",
    "aggregate": "python3 webpack_script.py ../../..",
    "aggregate:tests": "python3 webpack_script.py ../../.. --with-tests",
    "test": "yarn aggregate:tests && vitest run",
    "test:watch": "yarn aggregate:tests && vitest",
    "test:coverage": "yarn aggregate:tests && vitest run --coverage"
  },
  "version": "0.1.0",
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@emotion/react": "11.14.0",
