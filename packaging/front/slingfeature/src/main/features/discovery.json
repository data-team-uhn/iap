            "start-order":"20"
        },
        {
            "id":"org.apache.sling:org.apache.sling.discovery.commons:1.1.0",
            "start-order":"20"
        },
        {
            "id":"org.apache.sling:org.apache.sling.discovery.oak:1.2.48",
            "start-order":"20"
