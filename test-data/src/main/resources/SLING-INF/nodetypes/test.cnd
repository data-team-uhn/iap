<sling = 'http://sling.apache.org/jcr/sling/1.0'>
<iap = 'https://iap.uhndata.io/'>

// Concrete subtypes of the abstract base data types, only meant for testing the base type behavior.

// The homepage container for the test entities.
[iap:TestEntityHomepage] > iap:EntityHomepage
  // We can use test entity homepages in a query.
  query

// A minimal concrete entity.
[iap:TestEntity] > iap:Entity
  // We can use test entities in a query.
  query
