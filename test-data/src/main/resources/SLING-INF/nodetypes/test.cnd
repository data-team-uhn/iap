<sling = 'http://sling.apache.org/jcr/sling/1.0'>
<iap = 'https://iap.uhndata.io/'>

// Concrete subtypes of the abstract base data types, only meant for testing the base type behavior.

// The homepage container for the test resources.
[iap:TestResourceHomepage] > iap:ResourceHomepage
  // We can use test resource homepages in a query.
  query

// A minimal concrete resource.
[iap:TestResource] > iap:Resource
  // We can use test resources in a query.
  query
